extends baseEmail

block content
  //- Single table (header + card) to keep width consistent across email clients
  table(role='presentation', border='0', cellpadding='0', cellspacing='0', align='center', style='width: 100%;')
    tbody
      tr
        td.email-header(align='center')
          h2 Reset your password
      tr
        td.card(style='text-align: left;')
          p Hi #{firstName},
          p We received a request to reset your Tirhal password. Click the button below to set a new password.

          table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
            tbody
              tr
                td(align='center')
                  table(role='presentation', border='0', cellpadding='0', cellspacing='0')
                    tbody
                      tr
                        td
                          a(href=`${url}`, target='_blank') Reset your password

          p.muted If the button does not work, copy and paste this link into your browser:
          p: a(href=`${url}`, target='_blank')= url

          p.muted If you did not request a password reset, you can safely ignore this email.
          p - Mohamed Kotb
