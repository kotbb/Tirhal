extends base

block content
  main.main(class=showTourFilters ? 'main--tours-overview' : '')
    if showTourFilters
      .tour-sort
        label.tour-sort__bar(for='sort-tours')
          svg.tour-sort__lead-icon(viewBox='0 0 24 24' aria-hidden='true' focusable='false')
            path(fill='currentColor' d='M8 10l4-3 4 3H8zm0 4h8l-4 3-4-3z')
          span.tour-sort__prefix Sort By:
          select#sort-tours.tour-sort__select(name='sort' aria-label='Sort tours')
            option(value='newest' selected=(currentSort === 'newest')) Recommended
            option(value='price-asc' selected=(currentSort === 'price-asc')) Price: low to high
            option(value='price-desc' selected=(currentSort === 'price-desc')) Price: high to low
            option(value='rating' selected=(currentSort === 'rating')) Highest rated
            option(value='duration-asc' selected=(currentSort === 'duration-asc')) Duration: shortest
            option(value='duration-desc' selected=(currentSort === 'duration-desc')) Duration: longest
            option(value='name' selected=(currentSort === 'name')) Name (A–Z)
          svg.tour-sort__chevron(viewBox='0 0 24 24' aria-hidden='true' focusable='false')
            use(xlink:href='/img/icons.svg#icon-chevron-down')
      p.tour-sort__empty#tour-sort-empty(hidden=tours.length > 0) No tours match this sort. Try another option.

    .card-container#tour-cards
      each tour in tours
        .card
          .card__header
            .card__picture
              .card__picture-overlay &nbsp;
              img.card__picture-img(src=`/img/tours/${tour.imageCover}`, alt=`${tour.name}`)
            h3.heading-tertirary
              span #{tour.name}
          .card__details
            h4.card__sub-heading= `${tour.difficulty} ${tour.duration}-day tour`
            p.card__text #{tour.summary}
            .card__data
              svg.card__icon
                use(xlink:href=`/img/icons.svg#icon-map-pin`)
              span #{tour.startLocation.description}
            .card__data
              svg.card__icon
                use(xlink:href=`/img/icons.svg#icon-calendar`)
              span #{tour.startDates[0].toLocaleDateString('en-US', { month: 'long', year: 'numeric' })} 
            .card__data
              svg.card__icon
                use(xlink:href=`/img/icons.svg#icon-flag`)
              span #{tour.locations.length} stops
            .card__data
              svg.card__icon
                use(xlink:href=`/img/icons.svg#icon-user`)
              span #{tour.maxGroupSize} people
          .card__footer
            p.card__footer-link
              span.card__footer-value $#{tour.price}
              | 
              span.card__footer-text per person
            p.card__ratings
              span.card__footer-value #{tour.ratingsAverage}
              | 
              span.card__footer-text= `rating (${tour.ratingsQuantity})`
          a.btn.btn--green.btn--small(href=`/tour/${tour.slug}`) Details