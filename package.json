    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "core-js": "^3.45.1",
    "dompurify": "^3.2.7",
    "dotenv": "^17.2.0",
    "express": "^4.16.4",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "html-to-text": "^9.0.5",
    "jsdom": "^27.0.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "mongoose": "^8.16.5",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.6",
    "nodemon": "^3.1.10",
    "pug": "^3.0.3",
    "regenerator-runtime": "^0.14.1",
    "sharp": "^0.34.4",
    "slugify": "^1.6.6",
    "stripe": "^18.5.0",
    "validator": "^13.15.15",
    "xss": "^1.0.15"
